{
  "sidebar_action": {
    "default_panel": "src/sidepanel/index.html",
    "default_title": "Geo Image",
    "open_at_install": false
  },
  "background": {
    "scripts": ["service-worker-loader.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "geo-image@cssnr.com",
      "strict_min_version": "112.0",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "update_url": "https://raw.githubusercontent.com/cssnr/geo-image/master/update.json"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  }
}
